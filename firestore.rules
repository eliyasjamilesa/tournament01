
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // User profile rules
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // Tournament rules
    match /tournaments/{tournamentId} {
      allow read: if true;
      allow write: if isAdmin();
      
      // Individual registrations within a tournament
      match /registrations/{userId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      }
    }

    // Collection group rules for registrations (Crucial for Profile/Joined pages)
    match /{path=**}/registrations/{regDocId} {
      allow read: if isSignedIn();
    }
    
    // Transaction rules
    match /transactions/{transactionId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
  }
}
