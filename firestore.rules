
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // User profile rules - Anyone signed in can read (for leaderboard/display), only owner/admin can write
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // Tournament rules - Everyone can read, only admin can write
    match /tournaments/{tournamentId} {
      allow read: if true;
      allow write: if isAdmin();
      
      // Individual registrations
      match /registrations/{userId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      }
    }

    // Collection group queries for registrations (used in profile page)
    match /{path=**}/registrations/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }
    
    // Transaction rules - Users can create deposits/withdraws and read their own, admins can do everything
    match /transactions/{transactionId} {
      allow read: if isSignedIn() && (
        isAdmin() || 
        (resource != null && resource.data.userId == request.auth.uid) ||
        (request.method == 'get') // Allow individual lookups
      );
      
      allow create: if isSignedIn();
      
      // Only admins can update (approve/reject) or delete
      allow update, delete: if isAdmin();
    }
  }
}
