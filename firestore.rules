
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow public read for tournaments so metadata/results are visible
    // This prevents permission errors during auth initialization
    match /tournaments/{tournamentId} {
      allow read: if true;
      allow write: if request.auth != null;
      
      match /registrations/{userId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && (request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      }
    }
    
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    // General fallback for development
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
