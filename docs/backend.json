
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Information about a user in the IgniteArena platform.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string" },
        "phone": { "type": "string" },
        "coins": { "type": "number", "description": "Virtual currency for tournament entry." },
        "level": { "type": "number", "description": "User's experience level." },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "User's role in the platform." }
      },
      "required": ["uid", "email"]
    },
    "Tournament": {
      "title": "Tournament",
      "description": "A match or tournament event.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "matchId": { "type": "string", "description": "Custom Match ID like #26429" },
        "title": { "type": "string" },
        "mode": { "type": "string", "enum": ["BR SOLO", "BR DUO", "BR SQUAD", "CS RANK", "CS HEADSHOT", "LW 1V1", "LW 2V2", "LW HEADSHOT"] },
        "map": { "type": "string" },
        "version": { "type": "string", "enum": ["TPP", "FPP"] },
        "entryFee": { "type": "number" },
        "prizePool": { "type": "number" },
        "perKill": { "type": "number" },
        "maxPlayers": { "type": "number" },
        "currentPlayers": { "type": "number" },
        "startTime": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["open", "full", "live", "completed"] },
        "roomId": { "type": "string" },
        "roomPassword": { "type": "string" },
        "prizes": {
          "type": "object",
          "properties": {
            "p1": { "type": "number" },
            "p2": { "type": "number" },
            "p3": { "type": "number" },
            "p4": { "type": "number" },
            "p5": { "type": "number" }
          }
        }
      }
    },
    "Registration": {
      "title": "Registration",
      "description": "User registration for a tournament.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "ingameName": { "type": "string", "description": "The name used in the actual game." },
        "ingameId": { "type": "string", "description": "The unique ID used in the game." },
        "slotNumber": { "type": "number" },
        "wonAmount": { "type": "number", "description": "The amount won by the user in this match." },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Financial transactions for deposits or manual recharges.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "amount": { "type": "number" },
        "method": { "type": "string" },
        "transactionId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Individual user profiles."
    },
    "/tournaments/{tournamentId}": {
      "schema": "Tournament",
      "description": "Tournament listings managed by admin."
    },
    "/tournaments/{tournamentId}/registrations/{userId}": {
      "schema": "Registration",
      "description": "Records of users who joined the match."
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Log of deposit requests and recharges."
    }
  }
}
