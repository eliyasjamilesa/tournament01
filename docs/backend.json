
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Information about a user in the IgniteArena platform.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string" },
        "phone": { "type": "string" },
        "coins": { "type": "number", "description": "Virtual currency for tournament entry." },
        "level": { "type": "number", "description": "User's experience level." }
      },
      "required": ["uid", "email"]
    }
  },
  "auth": {
    "providers": ["google", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Individual user profiles."
    }
  }
}
